# --- Required for downstream pipeline (9 subagents + simulate) ---
# DeepSeek V4 pro, OpenAI-compatible API. Resolved by llm.yaml `default` section.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Optional: only set if you have direct Anthropic API access ---
# Used by llm.yaml `intake` section. Most users drive intake via a half-manual
# Claude Code session (see AI_agent/new_case_guide.md) and leave these blank.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- Other ---
QDRANT_ENDPOINT=
QDRANT_API_KEY=
GEMINI_API_KEY=

# Legacy single-LLM env vars (kept for compatibility with old flat llm.yaml).
# New code reads DEEPSEEK_* / ANTHROPIC_* above.
LLM_API_KEY=
LLM_BASE_URL=

# Optional LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=
