{
  "name": "EnergyPlus-Agent",
  "build": {
    "dockerfile": "Dockerfile",
    // 构建上下文设为 .devcontainer/ 本身 —— 该 Dockerfile 不 COPY 仓库代码,
    // 上下文越小构建越快(不必把 test_data/.git 等传给 Docker daemon)。
    "context": "."
  },
  // Node.js —— 三个 AI CLI 都是 npm 包,基础镜像没有 Node,用 feature 装。
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  // 容器首次创建后:
  //   1) uv sync 装 Python 依赖(含 dev 组:pytest / ruff),venv 落在 /opt/venv;
  //   2) npm 全局装 Claude Code / Codex / Gemini 三个 CLI。
  "postCreateCommand": "uv sync --frozen && npm install -g @anthropic-ai/claude-code @openai/codex @google/gemini-cli",
  // 挂载宿主机的 AI CLI 配置/登录态,容器内免重新登录。
  // ${localEnv:HOME}${localEnv:USERPROFILE} 兼容 Windows(USERPROFILE)与 Mac(HOME)。
  // 若某次挂载失败,删掉对应行、进容器后重新登录即可。
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/root/.claude,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/root/.claude.json,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.codex,target=/root/.codex,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gemini,target=/root/.gemini,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python"
      }
    }
  },
  // MCP server 的 HTTP 端口,需在容器里调试 server 时用得上。
  "forwardPorts": [8000]
}
