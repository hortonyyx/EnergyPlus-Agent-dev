{
  "name": "EnergyPlus-Agent",
  "build": {
    "dockerfile": "Dockerfile",
    // 构建上下文设为 .devcontainer/ 本身 —— 该 Dockerfile 不 COPY 仓库代码,
    // 上下文越小构建越快(不必把 test_data/.git 等传给 Docker daemon)。
    "context": "."
  },
  // Node.js 与三个 AI CLI 均不再用 devcontainer feature / postCreateCommand 装:
  //   - Node.js feature 来自 ghcr.io,国内网络下拉取常超时致容器创建失败,
  //     已改在 Dockerfile 用 NodeSource 装;
  //   - Claude Code / Codex / Gemini 三个 CLI 曾放 postCreateCommand,出现过
  //     "包装上了但 /usr/bin bin 软链接没建好"的静默半完成,已移进 Dockerfile。
  // postCreateCommand 现只剩 uv sync(装 Python 依赖,含 dev 组 pytest / ruff,
  // venv 落在 /opt/venv)—— 它依赖挂载进来的工作区代码,无法挪进构建期。
  "postCreateCommand": "uv sync --frozen",
  // 挂载宿主机的 AI CLI 配置/登录态,容器内免重新登录。
  // ${localEnv:HOME}${localEnv:USERPROFILE} 兼容 Windows(USERPROFILE)与 Mac(HOME)。
  // 若某次挂载失败,删掉对应行、进容器后重新登录即可。
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/root/.claude,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/root/.claude.json,type=bind",
    // codex 只挂认证文件:整目录挂载会让 state_*.sqlite 落在 Windows bind mount 上,
    // sqlite 文件锁不兼容 → "disk I/O error"。只挂 auth.json 复用登录态,
    // sqlite 留在容器本地文件系统。前提:宿主机 ~/.codex/auth.json 已存在。
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.codex/auth.json,target=/root/.codex/auth.json,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gemini,target=/root/.gemini,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python"
      }
    }
  },
  // MCP server 的 HTTP 端口,需在容器里调试 server 时用得上。
  "forwardPorts": [8000]
}
