{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Convert-IDF",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "convert-idf"
            ]
        },
        {
            "name": "MCP Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "mcp-server",
                "--transport",
                "streamable-http",
                "--host",
                "0.0.0.0",
                "--port",
                "8600"
            ]
        },
        {
            "name": "MCP + Inspector",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "mcp-server",
                "--transport",
                "streamable-http",
                "--host",
                "0.0.0.0",
                "--port",
                "8600"
            ],
            "preLaunchTask": "Start MCP Inspector"
        },
        {
            "name": "Embedding",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "embedding",
                "--collection",
                "energyplus_database",
                "--db-path",
                "${workspaceFolder}/data/examples/EP_Agent_data.db"
            ]
        },
        {
            "name": "Zone Agent",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_zone_agent.py",
                "-v"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Export Demo Trace",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/export_trace.py",
            "cwd": "${workspaceFolder}"
        }
    ]
}