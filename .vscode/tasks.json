{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start MCP Inspector",
            "type": "shell",
            "command": "npx",
            "args": ["@modelcontextprotocol/inspector"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "MCP Inspector"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "showReuseMessage": false
            }
        }
    ]
}