!- Linux Line endings 

VERSION,
    25.1.0;                   !- Version Identifier

SIMULATIONCONTROL,
    No,                       !- Do Zone Sizing Calculation
    No,                       !- Do System Sizing Calculation
    No,                       !- Do Plant Sizing Calculation
    Yes,                      !- Run Simulation for Sizing Periods
    Yes,                      !- Run Simulation for Weather File Run Periods
    Yes,                      !- Do HVAC Sizing Simulation for Sizing Periods
    1;                        !- Maximum Number of HVAC Sizing Simulation Passes

BUILDING,
    smalloffice_22,           !- Name
    0,                        !- North Axis
    Suburbs,                  !- Terrain
    0.04,                     !- Loads Convergence Tolerance Value
    0.4,                      !- Temperature Convergence Tolerance Value
    FullExterior,             !- Solar Distribution
    25,                       !- Maximum Number of Warmup Days
    1;                        !- Minimum Number of Warmup Days

SITE:LOCATION,
    Shenzhen_CN,              !- Name
    22.5431,                  !- Latitude
    114.0579,                 !- Longitude
    8,                        !- Time Zone
    0;                        !- Elevation

RUNPERIOD,
    Default Run Period,       !- Name
    1,                        !- Begin Month
    1,                        !- Begin Day of Month
    ,                         !- Begin Year
    12,                       !- End Month
    31,                       !- End Day of Month
    ,                         !- End Year
    ,                         !- Day of Week for Start Day
    Yes,                      !- Use Weather File Holidays and Special Days
    Yes,                      !- Use Weather File Daylight Saving Period
    No,                       !- Apply Weekend Holiday Rule
    Yes,                      !- Use Weather File Rain Indicators
    Yes,                      !- Use Weather File Snow Indicators
    No,                       !- Treat Weather as Actual
    Hour24;                   !- First Hour Interpolation Starting Values

SCHEDULETYPELIMITS,
    Fraction,                 !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    Temperature,              !- Name
    -100,                     !- Lower Limit Value
    100,                      !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Temperature;              !- Unit Type

SCHEDULETYPELIMITS,
    Activity Level,           !- Name
    0,                        !- Lower Limit Value
    1000,                     !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    OnOff,                    !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    DISCRETE,                 !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULE:COMPACT,
    Sch_Office_Occupancy,     !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 09:00, 0.0,        !- Field 3
    Until: 18:00, 1.0,        !- Field 4
    Until: 24:00, 0.0,        !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 0.0;        !- Field 7

SCHEDULE:COMPACT,
    Sch_Office_Lighting,      !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 09:00, 0.0,        !- Field 3
    Until: 18:00, 1.0,        !- Field 4
    Until: 24:00, 0.0,        !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 0.0;        !- Field 7

SCHEDULE:COMPACT,
    Sch_Office_HtgSetp,       !- Name
    Temperature,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 20.0;       !- Field 3

SCHEDULE:COMPACT,
    Sch_Office_ClgSetp,       !- Name
    Temperature,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 24.0;       !- Field 3

SCHEDULE:COMPACT,
    Sch_Office_Activity,      !- Name
    Activity Level,           !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 120.0;      !- Field 3

SCHEDULE:COMPACT,
    Sch_Office_IdealLoadsAvail,    !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 1.0;        !- Field 3

MATERIAL,
    Mat_Stucco,               !- Name
    Rough,                    !- Roughness
    0.0254,                   !- Thickness
    0.6918,                   !- Conductivity
    1858,                     !- Density
    837,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Insulation,           !- Name
    Rough,                    !- Roughness
    0.05,                     !- Thickness
    0.04,                     !- Conductivity
    50,                       !- Density
    840,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Gypsum,               !- Name
    Smooth,                   !- Roughness
    0.0127,                   !- Thickness
    0.16,                     !- Conductivity
    800,                      !- Density
    1090,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_MetalRoof,            !- Name
    Smooth,                   !- Roughness
    0.0015,                   !- Thickness
    45,                       !- Conductivity
    7800,                     !- Density
    500,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_RoofInsulation,       !- Name
    Rough,                    !- Roughness
    0.1,                      !- Thickness
    0.04,                     !- Conductivity
    50,                       !- Density
    840,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Concrete,             !- Name
    MediumRough,              !- Roughness
    0.2,                      !- Thickness
    1.4,                      !- Conductivity
    2240,                     !- Density
    880,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    Mat_Glazing_Simple,       !- Name
    2.5,                      !- UFactor
    0.6,                      !- Solar Heat Gain Coefficient
    ;                         !- Visible Transmittance

CONSTRUCTION,
    Default_Ext_Wall,         !- Name
    Mat_Stucco,               !- Outside Layer
    Mat_Insulation,           !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Default_Int_Wall,         !- Name
    Mat_Gypsum;               !- Outside Layer

CONSTRUCTION,
    Default_GroundFloor,      !- Name
    Mat_Concrete;             !- Outside Layer

CONSTRUCTION,
    Default_Roof,             !- Name
    Mat_MetalRoof,            !- Outside Layer
    Mat_RoofInsulation,       !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Cons_InterFloor,          !- Name
    Mat_Concrete;             !- Outside Layer

CONSTRUCTION,
    Default_Window,           !- Name
    Mat_Glazing_Simple;       !- Outside Layer

GLOBALGEOMETRYRULES,
    UpperLeftCorner,          !- Starting Vertex Position
    Counterclockwise,         !- Vertex Entry Direction
    World,                    !- Coordinate System
    Relative,                 !- Daylighting Reference Point Coordinate System
    Relative;                 !- Rectangular Surface Coordinate System

