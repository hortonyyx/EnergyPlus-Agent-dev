!- Linux Line endings 

VERSION,
    25.1.0;                   !- Version Identifier

SIMULATIONCONTROL,
    No,                       !- Do Zone Sizing Calculation
    No,                       !- Do System Sizing Calculation
    No,                       !- Do Plant Sizing Calculation
    Yes,                      !- Run Simulation for Sizing Periods
    Yes,                      !- Run Simulation for Weather File Run Periods
    Yes,                      !- Do HVAC Sizing Simulation for Sizing Periods
    1;                        !- Maximum Number of HVAC Sizing Simulation Passes

BUILDING,
    smalloffice_21,           !- Name
    0,                        !- North Axis
    Suburbs,                  !- Terrain
    0.04,                     !- Loads Convergence Tolerance Value
    0.4,                      !- Temperature Convergence Tolerance Value
    FullExterior,             !- Solar Distribution
    25,                       !- Maximum Number of Warmup Days
    1;                        !- Minimum Number of Warmup Days

SITE:LOCATION,
    Shenzhen_CN,              !- Name
    22.54,                    !- Latitude
    114.06,                   !- Longitude
    8,                        !- Time Zone
    0;                        !- Elevation

RUNPERIOD,
    Default Run Period,       !- Name
    1,                        !- Begin Month
    1,                        !- Begin Day of Month
    ,                         !- Begin Year
    12,                       !- End Month
    31,                       !- End Day of Month
    ,                         !- End Year
    ,                         !- Day of Week for Start Day
    Yes,                      !- Use Weather File Holidays and Special Days
    Yes,                      !- Use Weather File Daylight Saving Period
    No,                       !- Apply Weekend Holiday Rule
    Yes,                      !- Use Weather File Rain Indicators
    Yes,                      !- Use Weather File Snow Indicators
    No,                       !- Treat Weather as Actual
    Hour24;                   !- First Hour Interpolation Starting Values

SCHEDULETYPELIMITS,
    Fraction,                 !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    Temperature,              !- Name
    -100,                     !- Lower Limit Value
    100,                      !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Temperature;              !- Unit Type

SCHEDULETYPELIMITS,
    ActivityLevel,            !- Name
    0,                        !- Lower Limit Value
    1000,                     !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    OnOff,                    !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    DISCRETE,                 !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULE:COMPACT,
    Sched_Thermo_Heat,        !- Name
    Temperature,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 07:00, 15.0,       !- Field 3
    Until: 09:00, 21.0,       !- Field 4
    Until: 18:00, 21.0,       !- Field 5
    Until: 24:00, 18.0,       !- Field 6
    For: Weekends,            !- Field 7
    Until: 24:00, 15.0,       !- Field 8
    For: Holidays,            !- Field 9
    Until: 24:00, 15.0;       !- Field 10

SCHEDULE:COMPACT,
    Sched_Thermo_Cool,        !- Name
    Temperature,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 07:00, 30.0,       !- Field 3
    Until: 09:00, 24.0,       !- Field 4
    Until: 18:00, 24.0,       !- Field 5
    Until: 24:00, 28.0,       !- Field 6
    For: Weekends,            !- Field 7
    Until: 24:00, 30.0,       !- Field 8
    For: Holidays,            !- Field 9
    Until: 24:00, 30.0;       !- Field 10

SCHEDULE:COMPACT,
    Sched_HVAC_Avail,         !- Name
    OnOff,                    !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 06:00, 0.0,        !- Field 3
    Until: 20:00, 1.0,        !- Field 4
    Until: 24:00, 0.0,        !- Field 5
    For: Weekends,            !- Field 6
    Until: 24:00, 0.0,        !- Field 7
    For: Holidays,            !- Field 8
    Until: 24:00, 0.0;        !- Field 9

SCHEDULE:COMPACT,
    Sched_Occupancy,          !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 08:00, 0.0,        !- Field 3
    Until: 09:00, 0.3,        !- Field 4
    Until: 12:00, 0.9,        !- Field 5
    Until: 13:00, 0.3,        !- Field 6
    Until: 17:00, 0.9,        !- Field 7
    Until: 18:00, 0.3,        !- Field 8
    Until: 24:00, 0.0,        !- Field 9
    For: Weekends,            !- Field 10
    Until: 24:00, 0.0,        !- Field 11
    For: Holidays,            !- Field 12
    Until: 24:00, 0.0;        !- Field 13

SCHEDULE:COMPACT,
    Sched_Activity,           !- Name
    ActivityLevel,            !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 120.0;      !- Field 3

SCHEDULE:COMPACT,
    Sched_Lights,             !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 08:00, 0.1,        !- Field 3
    Until: 09:00, 0.5,        !- Field 4
    Until: 12:00, 1.0,        !- Field 5
    Until: 13:00, 0.8,        !- Field 6
    Until: 17:00, 1.0,        !- Field 7
    Until: 18:00, 0.5,        !- Field 8
    Until: 24:00, 0.1,        !- Field 9
    For: Weekends,            !- Field 10
    Until: 24:00, 0.05,       !- Field 11
    For: Holidays,            !- Field 12
    Until: 24:00, 0.05;       !- Field 13

MATERIAL,
    Mat_ExtWall_Stucco,       !- Name
    MediumRough,              !- Roughness
    0.025,                    !- Thickness
    0.692,                    !- Conductivity
    1858,                     !- Density
    837,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_ExtWall_Insulation,    !- Name
    MediumRough,              !- Roughness
    0.05,                     !- Thickness
    0.043,                    !- Conductivity
    91,                       !- Density
    837,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_ExtWall_Gypsum,       !- Name
    MediumSmooth,             !- Roughness
    0.013,                    !- Thickness
    0.16,                     !- Conductivity
    800,                      !- Density
    1090,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_IntWall_Gypsum,       !- Name
    MediumSmooth,             !- Roughness
    0.013,                    !- Thickness
    0.16,                     !- Conductivity
    800,                      !- Density
    1090,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Floor_Concrete,       !- Name
    MediumRough,              !- Roughness
    0.15,                     !- Thickness
    1.4,                      !- Conductivity
    2240,                     !- Density
    840,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_GroundFloor_Carpet,    !- Name
    MediumSmooth,             !- Roughness
    0.01,                     !- Thickness
    0.06,                     !- Conductivity
    288,                      !- Density
    1380,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Roof_Membrane,        !- Name
    MediumSmooth,             !- Roughness
    0.01,                     !- Thickness
    0.16,                     !- Conductivity
    1120,                     !- Density
    1460,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Roof_Insulation,      !- Name
    MediumRough,              !- Roughness
    0.1,                      !- Thickness
    0.043,                    !- Conductivity
    91,                       !- Density
    837,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Roof_Deck,            !- Name
    MediumRough,              !- Roughness
    0.02,                     !- Thickness
    0.14,                     !- Conductivity
    530,                      !- Density
    900,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    Mat_Glazing_DoubleLowE,    !- Name
    1.8,                      !- UFactor
    0.35,                     !- Solar Heat Gain Coefficient
    0.6;                      !- Visible Transmittance

CONSTRUCTION,
    Default_Ext_Wall,         !- Name
    Mat_ExtWall_Stucco,       !- Outside Layer
    Mat_ExtWall_Insulation,    !- Layer 2
    Mat_ExtWall_Gypsum;       !- Layer 3

CONSTRUCTION,
    Default_Int_Wall,         !- Name
    Mat_IntWall_Gypsum;       !- Outside Layer

CONSTRUCTION,
    Default_Window,           !- Name
    Mat_Glazing_DoubleLowE;    !- Outside Layer

CONSTRUCTION,
    Default_GroundFloor,      !- Name
    Mat_GroundFloor_Carpet,    !- Outside Layer
