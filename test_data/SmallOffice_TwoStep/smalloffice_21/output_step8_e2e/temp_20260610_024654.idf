MATERIAL,
    Mat_Stucco,               !- Name
    Smooth,                   !- Roughness
    0.025,                    !- Thickness
    0.72,                     !- Conductivity
    1856,                     !- Density
    840,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Insulation,           !- Name
    MediumRough,              !- Roughness
    0.1,                      !- Thickness
    0.04,                     !- Conductivity
    91,                       !- Density
    837,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Gypsum,               !- Name
    Smooth,                   !- Roughness
    0.0127,                   !- Thickness
    0.16,                     !- Conductivity
    800,                      !- Density
    1090,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Floor_Concrete,       !- Name
    Rough,                    !- Roughness
    0.15,                     !- Thickness
    1.73,                     !- Conductivity
    2243,                     !- Density
    837,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Roof_Membrane,        !- Name
    VeryRough,                !- Roughness
    0.0095,                   !- Thickness
    0.16,                     !- Conductivity
    1121,                     !- Density
    1460,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    Mat_SimpleGlazing,        !- Name
    2.5,                      !- UFactor
    0.6,                      !- Solar Heat Gain Coefficient
    ;                         !- Visible Transmittance

CONSTRUCTION,
    Default_Ext_Wall,         !- Name
    Mat_Stucco,               !- Outside Layer
    Mat_Insulation,           !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Default_Int_Wall,         !- Name
    Mat_Gypsum,               !- Outside Layer
    Mat_Insulation,           !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Default_GroundFloor,      !- Name
    Mat_Floor_Concrete,       !- Outside Layer
    Mat_Insulation,           !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Default_Roof,             !- Name
    Mat_Roof_Membrane,        !- Outside Layer
    Mat_Insulation,           !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Cons_InterFloor,          !- Name
    Mat_Floor_Concrete;       !- Outside Layer

CONSTRUCTION,
    Default_Window,           !- Name
    Mat_SimpleGlazing;        !- Outside Layer

GLOBALGEOMETRYRULES,
    UpperLeftCorner,          !- Starting Vertex Position
    Counterclockwise,         !- Vertex Entry Direction
    World,                    !- Coordinate System
    Relative,                 !- Daylighting Reference Point Coordinate System
    Relative;                 !- Rectangular Surface Coordinate System

