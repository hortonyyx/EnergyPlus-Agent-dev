!- Linux Line endings 

VERSION,
    25.1.0;                   !- Version Identifier

SIMULATIONCONTROL,
    No,                       !- Do Zone Sizing Calculation
    No,                       !- Do System Sizing Calculation
    No,                       !- Do Plant Sizing Calculation
    Yes,                      !- Run Simulation for Sizing Periods
    Yes,                      !- Run Simulation for Weather File Run Periods
    Yes,                      !- Do HVAC Sizing Simulation for Sizing Periods
    1;                        !- Maximum Number of HVAC Sizing Simulation Passes

BUILDING,
    smalloffice_21,           !- Name
    0,                        !- North Axis
    City,                     !- Terrain
    0.04,                     !- Loads Convergence Tolerance Value
    0.4,                      !- Temperature Convergence Tolerance Value
    FullExterior,             !- Solar Distribution
    25,                       !- Maximum Number of Warmup Days
    1;                        !- Minimum Number of Warmup Days

SITE:LOCATION,
    Shenzhen_CN,              !- Name
    22.55,                    !- Latitude
    114.1,                    !- Longitude
    8,                        !- Time Zone
    5;                        !- Elevation

RUNPERIOD,
    Default Run Period,       !- Name
    1,                        !- Begin Month
    1,                        !- Begin Day of Month
    ,                         !- Begin Year
    12,                       !- End Month
    31,                       !- End Day of Month
    ,                         !- End Year
    ,                         !- Day of Week for Start Day
    Yes,                      !- Use Weather File Holidays and Special Days
    Yes,                      !- Use Weather File Daylight Saving Period
    No,                       !- Apply Weekend Holiday Rule
    Yes,                      !- Use Weather File Rain Indicators
    Yes,                      !- Use Weather File Snow Indicators
    No,                       !- Treat Weather as Actual
    Hour24;                   !- First Hour Interpolation Starting Values

SCHEDULETYPELIMITS,
    Frac_Limits,              !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    Temp_Limits,              !- Name
    10,                       !- Lower Limit Value
    40,                       !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Temperature;              !- Unit Type

SCHEDULETYPELIMITS,
    Activity_Limits,          !- Name
    0,                        !- Lower Limit Value
    1000,                     !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    OnOff_Limits,             !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    DISCRETE,                 !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULE:COMPACT,
    Office_Occupancy,         !- Name
    Frac_Limits,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 09:00, 0.0,        !- Field 3
    Until: 18:00, 1.0,        !- Field 4
    Until: 24:00, 0.0,        !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 0.0;        !- Field 7

SCHEDULE:COMPACT,
    Office_Activity,          !- Name
    Activity_Limits,          !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 120.0;      !- Field 3

SCHEDULE:COMPACT,
    Office_Lights,            !- Name
    Frac_Limits,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 09:00, 0.1,        !- Field 3
    Until: 18:00, 1.0,        !- Field 4
    Until: 24:00, 0.1,        !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 0.05;       !- Field 7

SCHEDULE:COMPACT,
    HVAC_Avail,               !- Name
    OnOff_Limits,             !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 07:00, 0.0,        !- Field 3
    Until: 20:00, 1.0,        !- Field 4
    Until: 24:00, 0.0,        !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 0.0;        !- Field 7

SCHEDULE:COMPACT,
    Heating_Setpoint,         !- Name
    Temp_Limits,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 07:00, 16.0,       !- Field 3
    Until: 20:00, 20.0,       !- Field 4
    Until: 24:00, 16.0,       !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 16.0;       !- Field 7

SCHEDULE:COMPACT,
    Cooling_Setpoint,         !- Name
    Temp_Limits,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 07:00, 30.0,       !- Field 3
    Until: 20:00, 24.0,       !- Field 4
    Until: 24:00, 30.0,       !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 30.0;       !- Field 7

MATERIAL,
    Mat_Stucco,               !- Name
    Smooth,                   !- Roughness
    0.025,                    !- Thickness
    0.72,                     !- Conductivity
    1856,                     !- Density
    840,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Insulation,           !- Name
    MediumRough,              !- Roughness
    0.08,                     !- Thickness
    0.043,                    !- Conductivity
    32,                       !- Density
    835,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Gypsum,               !- Name
    Smooth,                   !- Roughness
    0.016,                    !- Thickness
    0.16,                     !- Conductivity
    800,                      !- Density
    1090,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_Concrete,             !- Name
    MediumRough,              !- Roughness
    0.15,                     !- Thickness
    1.95,                     !- Conductivity
    2240,                     !- Density
    900,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_RoofInsulation,       !- Name
    MediumRough,              !- Roughness
    0.12,                     !- Thickness
    0.043,                    !- Conductivity
    32,                       !- Density
    835,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Mat_RoofMembrane,         !- Name
    VeryRough,                !- Roughness
    0.01,                     !- Thickness
    0.16,                     !- Conductivity
    1120,                     !- Density
    1460,                     !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    Mat_Window_Glazing,       !- Name
    2.5,                      !- UFactor
    0.4,                      !- Solar Heat Gain Coefficient
    0.6;                      !- Visible Transmittance

CONSTRUCTION,
    Default_Ext_Wall,         !- Name
    Mat_Stucco,               !- Outside Layer
    Mat_Insulation,           !- Layer 2
    Mat_Gypsum;               !- Layer 3

CONSTRUCTION,
    Default_Int_Wall,         !- Name
    Mat_Gypsum,               !- Outside Layer
    Mat_Gypsum;               !- Layer 2

CONSTRUCTION,
    Default_GroundFloor,      !- Name
    Mat_Concrete;             !- Outside Layer

CONSTRUCTION,
    Default_Roof,             !- Name
    Mat_RoofMembrane,         !- Outside Layer
    Mat_RoofInsulation,       !- Layer 2
    Mat_Concrete;             !- Layer 3

CONSTRUCTION,
    Cons_InterFloor,          !- Name
    Mat_Concrete,             !- Outside Layer
    Mat_Gypsum;               !- Layer 2

CONSTRUCTION,
    Default_Window,           !- Name
    Mat_Window_Glazing;       !- Outside Layer

GLOBALGEOMETRYRULES,
    UpperLeftCorner,          !- Starting Vertex Position
    Counterclockwise,         !- Vertex Entry Direction
    World,                    !- Coordinate System
    Relative,                 !- Daylighting Reference Point Coordinate System
    Relative;                 !- Rectangular Surface Coordinate System

