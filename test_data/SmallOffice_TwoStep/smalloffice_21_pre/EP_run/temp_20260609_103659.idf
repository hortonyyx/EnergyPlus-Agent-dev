!- Linux Line endings 

VERSION,
    25.1.0;                   !- Version Identifier

SIMULATIONCONTROL,
    No,                       !- Do Zone Sizing Calculation
    No,                       !- Do System Sizing Calculation
    No,                       !- Do Plant Sizing Calculation
    Yes,                      !- Run Simulation for Sizing Periods
    Yes,                      !- Run Simulation for Weather File Run Periods
    Yes,                      !- Do HVAC Sizing Simulation for Sizing Periods
    1;                        !- Maximum Number of HVAC Sizing Simulation Passes

BUILDING,
    smalloffice_21_pre,       !- Name
    0,                        !- North Axis
    Suburbs,                  !- Terrain
    0.04,                     !- Loads Convergence Tolerance Value
    0.4,                      !- Temperature Convergence Tolerance Value
    FullExterior,             !- Solar Distribution
    25,                       !- Maximum Number of Warmup Days
    1;                        !- Minimum Number of Warmup Days

SITE:LOCATION,
    Shenzhen_CN,              !- Name
    22.54,                    !- Latitude
    114.06,                   !- Longitude
    8,                        !- Time Zone
    0;                        !- Elevation

RUNPERIOD,
    Default Run Period,       !- Name
    1,                        !- Begin Month
    1,                        !- Begin Day of Month
    ,                         !- Begin Year
    12,                       !- End Month
    31,                       !- End Day of Month
    ,                         !- End Year
    ,                         !- Day of Week for Start Day
    Yes,                      !- Use Weather File Holidays and Special Days
    Yes,                      !- Use Weather File Daylight Saving Period
    No,                       !- Apply Weekend Holiday Rule
    Yes,                      !- Use Weather File Rain Indicators
    Yes,                      !- Use Weather File Snow Indicators
    No,                       !- Treat Weather as Actual
    Hour24;                   !- First Hour Interpolation Starting Values

SCHEDULETYPELIMITS,
    Fraction,                 !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    Temperature,              !- Name
    -100,                     !- Lower Limit Value
    100,                      !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Temperature;              !- Unit Type

SCHEDULETYPELIMITS,
    Activity Level,           !- Name
    0,                        !- Lower Limit Value
    1000,                     !- Upper Limit Value
    CONTINUOUS,               !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULETYPELIMITS,
    OnOff,                    !- Name
    0,                        !- Lower Limit Value
    1,                        !- Upper Limit Value
    DISCRETE,                 !- Numeric Type
    Dimensionless;            !- Unit Type

SCHEDULE:COMPACT,
    Sch_Office_Heating_SP,    !- Name
    Temperature,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 06:00, 15.0,       !- Field 3
    Until: 18:00, 20.0,       !- Field 4
    Until: 24:00, 15.0,       !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 15.0;       !- Field 7

SCHEDULE:COMPACT,
    Sch_Office_Cooling_SP,    !- Name
    Temperature,              !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 06:00, 30.0,       !- Field 3
    Until: 18:00, 24.0,       !- Field 4
    Until: 24:00, 30.0,       !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 30.0;       !- Field 7

SCHEDULE:COMPACT,
    Sch_Office_IdealLoads_Avail,    !- Name
    OnOff,                    !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 06:00, 0.0,        !- Field 3
    Until: 18:00, 1.0,        !- Field 4
    Until: 24:00, 0.0,        !- Field 5
    For: AllOtherDays,        !- Field 6
    Until: 24:00, 0.0;        !- Field 7

SCHEDULE:COMPACT,
    Sch_Office_People_Number,    !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 06:00, 0.0,        !- Field 3
    Until: 09:00, 0.1,        !- Field 4
    Until: 12:00, 1.0,        !- Field 5
    Until: 13:00, 0.3,        !- Field 6
    Until: 18:00, 1.0,        !- Field 7
    Until: 24:00, 0.1,        !- Field 8
    For: AllOtherDays,        !- Field 9
    Until: 24:00, 0.0;        !- Field 10

SCHEDULE:COMPACT,
    Sch_Office_People_Activity,    !- Name
    Activity Level,           !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: AllDays,             !- Field 2
    Until: 24:00, 120.0;      !- Field 3

SCHEDULE:COMPACT,
    Sch_Office_Lights,        !- Name
    Fraction,                 !- Schedule Type Limits Name
    Through: 12/31,           !- Field 1
    For: Weekdays,            !- Field 2
    Until: 06:00, 0.0,        !- Field 3
    Until: 09:00, 0.3,        !- Field 4
    Until: 12:00, 1.0,        !- Field 5
    Until: 13:00, 0.5,        !- Field 6
    Until: 18:00, 1.0,        !- Field 7
    Until: 24:00, 0.3,        !- Field 8
    For: AllOtherDays,        !- Field 9
    Until: 24:00, 0.0;        !- Field 10

MATERIAL:NOMASS,
    Mat_ExtWall_Stucco,       !- Name
    MediumRough,              !- Roughness
    0.15,                     !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_ExtWall_Insulation,    !- Name
    MediumRough,              !- Roughness
    1.5,                      !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_ExtWall_Gypsum,       !- Name
    MediumSmooth,             !- Roughness
    0.08,                     !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_IntWall_Gypsum,       !- Name
    MediumSmooth,             !- Roughness
    0.08,                     !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_Floor_Concrete,       !- Name
    Rough,                    !- Roughness
    0.2,                      !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_Roof_Membrane,        !- Name
    MediumRough,              !- Roughness
    0.1,                      !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_Roof_Insulation,      !- Name
    MediumRough,              !- Roughness
    2,                        !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    Mat_Roof_Deck,            !- Name
    Rough,                    !- Roughness
    0.15,                     !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    Mat_Glazing_Default,      !- Name
    3,                        !- UFactor
    0.7,                      !- Solar Heat Gain Coefficient
    ;                         !- Visible Transmittance

CONSTRUCTION,
    Default_Ext_Wall,         !- Name
    Mat_ExtWall_Stucco,       !- Outside Layer
    Mat_ExtWall_Insulation,    !- Layer 2
    Mat_ExtWall_Gypsum;       !- Layer 3

CONSTRUCTION,
    Default_Int_Wall,         !- Name
    Mat_IntWall_Gypsum;       !- Outside Layer

CONSTRUCTION,
    Default_Window,           !- Name
    Mat_Glazing_Default;      !- Outside Layer

CONSTRUCTION,
    Default_GroundFloor,      !- Name
    Mat_Floor_Concrete;       !- Outside Layer

CONSTRUCTION,
    Default_Roof,             !- Name
    Mat_Roof_Membrane,        !- Outside Layer
    Mat_Roof_Insulation,      !- Layer 2
    Mat_Roof_Deck;            !- Layer 3

CONSTRUCTION,
    Cons_InterFloor,          !- Name
    Mat_Floor_Concrete,       !- Outside Layer
    Mat_IntWall_Gypsum;       !- Layer 2

GLOBALGEOMETRYRULES,
    UpperLeftCorner,          !- Starting Vertex Position
    Counterclockwise,         !- Vertex Entry Direction
    World,                    !- Coordinate System
    Relative,                 !- Daylighting Reference Point Coordinate System
    Relative;                 !- Rectangular Surface Coordinate System

